{
  "name": "@camera.ui/sdk-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "camera.ui sdk monorepo",
  "type": "module",
  "scripts": {
    "build:node": "npm --prefix node run build",
    "build:go": "cd go && go build ./...",
    "build:python": "cd python && python scripts/build.py --local",
    "build": "npm run build:node && npm run build:go && npm run build:python",
    "lint:node": "npm --prefix node run format && npm --prefix node run lint:fix",
    "lint:go": "cd go && gofmt -w . && go fix ./... && staticcheck ./... && golangci-lint run ./...",
    "lint:python": "cd python && mypy --config-file ../mypy.ini camera_ui_sdk",
    "lint": "npm run lint:node && npm run lint:go && npm run lint:python",
    "test:unit:node": "npm --prefix node test",
    "test:unit:go": "cd go && go test ./...",
    "test:unit:python": "cd python && python -m pytest",
    "test:unit": "npm run test:unit:node && npm run test:unit:go && npm run test:unit:python",
    "test": "npm run test:unit",
    "release": "bash scripts/release.sh",
    "update": "updates --file go,node,python --update ./"
  },
  "homepage": "https://github.com/cameraui/sdk#readme",
  "bugs": {
    "url": "https://github.com/cameraui/sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cameraui/sdk.git"
  },
  "license": "MIT",
  "author": "seydx",
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "9.39.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.61.0",
    "updates": "^17.18.0"
  }
}
